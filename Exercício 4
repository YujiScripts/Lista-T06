import java.util.Scanner;
public class Exercicio04 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Segundos para contagem: ");
        int t = sc.nextInt();
        while (t >= 0) {
            System.out.println("Sistema operando. T-menos " + t + " segundos;");
            t--;
        }
    }
}
