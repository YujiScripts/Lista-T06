import java.util.Scanner;
public class Exercicio08 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Início (K), Fim (K) e Passo: ");
        double k = sc.nextDouble(), fim = sc.nextDouble(), passo = sc.nextDouble();
        System.out.println("Kelvin\t| Celsius");
        while (k <= fim) {
            System.out.printf("%.2f K\t| %.2f C\n", k, (k - 273.15));
            k += passo;
        }
    }
}
