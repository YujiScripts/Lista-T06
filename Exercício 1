import java.util.Scanner;
public class Exercicio01 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Digite um número: ");
        int num = sc.nextInt();
        for (int i = 1; i <= 10; i++) {
            int res = num * i;
            if (res % 3 == 0) System.out.println(num + " x " + i + " = " + res);
        }
    }
}
